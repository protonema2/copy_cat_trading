# Mirrors .gitignore, plus a few extras specifically to keep the agent
# from reading/searching/indexing large or sensitive paths.

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Node / frontend build
node_modules/
frontend/node_modules/
frontend/dist/
dist/

# Local secrets and runtime state - never read these into context
.env
backend/.env
backend/.env.prod
*.session
backend/sessions/

# Local databases and logs
*.db
*.sqlite
*.sqlite3
*.log

# Legacy local bot runner with machine-specific credentials
copy_trader.py

# Git internals
.git/

# OS/editor noise
.DS_Store
Thumbs.db

# Lockfiles (large, rarely need full-content reads)
frontend/package-lock.json
